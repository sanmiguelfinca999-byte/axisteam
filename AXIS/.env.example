# ============================================================
# AXIS — variables de entorno
# Copia este archivo a `.env.local` y rellena con tus credenciales
# ============================================================

# --- Supabase (opcional pero recomendado para multi-usuario) ---
# Sin estas, AXIS opera en modo localStorage (single device)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# --- Branding (opcional) ---
VITE_AXIS_BRAND_NAME=AXIS
VITE_AXIS_BRAND_TAGLINE=The Execution OS
